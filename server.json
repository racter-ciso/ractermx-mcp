{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.racter-ciso/ractermx",
  "title": "RacterMX",
  "description": "Manage RacterMX email forwarding — domains, aliases, DNS zones, webhooks, and more — via AI.",
  "repository": {
    "url": "https://github.com/racter-ciso/ractermx-mcp",
    "source": "github"
  },
  "version": "2.2.0",
  "packages": [
    {
      "registryType": "npm",
      "identifier": "@ractermx/mcp-server",
      "version": "2.2.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "RACTERMX_API_KEY",
          "description": "Your RacterMX API key (sk_*)",
          "isRequired": true,
          "format": "string",
          "isSecret": true
        },
        {
          "name": "RACTERMX_API_URL",
          "description": "RacterMX API base URL (defaults to https://ractermx.com)",
          "isRequired": false,
          "format": "string",
          "isSecret": false
        }
      ]
    }
  ]
}
